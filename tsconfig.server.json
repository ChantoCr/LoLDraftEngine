{
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023"],
    "ignoreDeprecations": "6.0",
    "module": "esnext",
    "moduleResolution": "bundler",
    "types": ["node"],
    "skipLibCheck": true,
    "strict": true,
    "esModuleInterop": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "outDir": "./dist-server",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@server/*": ["server/*"]
    },
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": [
    "server/**/*.ts",
    "src/domain/**/*.ts",
    "src/data/mock/**/*.ts",
    "src/data/providers/live/backendApi/types.ts"
  ],
  "exclude": ["src/**/*.test.ts", "server/**/*.test.ts", "src/**/*.tsx"]
}
